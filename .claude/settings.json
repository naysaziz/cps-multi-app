{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Find",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(npm run:*)",
      "Bash(npx prisma:*)",
      "Bash(npx shadcn:*)",
      "Bash(npx shadcn@latest:*)",
      "Bash(mkdir:*)",
      "Bash(gws sheets spreadsheets get:*)",
      "Bash(gws sheets spreadsheets values get:*)",
      "Bash(gws sheets spreadsheets values batchGet:*)",
      "Bash(gws drive files get:*)",
      "Bash(gws drive files list:*)",
      "Bash(gws schema:*)"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -r:*)",
      "Read(.env.local)",
      "Read(.env.development)",
      "Read(.env.production)",
      "Read(.env.test)"
    ]
  }
}
